# Copy to .env and adjust. Used by Docker Compose and local runs.
DATABASE_URL=postgresql+asyncpg://mess:mess@localhost:5432/mess_todo
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Auto-created first admin when DB has no users
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-strong-password
INITIAL_ADMIN_FULL_NAME=Системный администратор
STORAGE_BACKEND=minio # Если локально то - local, minio - файлы будут в minio
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mess-workspace
MINIO_PUBLIC_BASE_URL=http://localhost:9000
